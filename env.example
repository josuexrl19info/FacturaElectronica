# Firebase Configuration
# Reemplaza estos valores con tu configuración real de Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# App Configuration
NEXT_PUBLIC_APP_NAME=InvoSell
NEXT_PUBLIC_COMPANY_NAME=InnovaSell
APP_URL=http://localhost:3000

# Nylas v3
NYLAS_API_KEY=your-nylas-api-key
NYLAS_CLIENT_ID=your-nylas-client-id
NYLAS_CALLBACK_URI=http://localhost:3000/api/nylas/oauth/callback
NYLAS_API_URI=https://api.us.nylas.com

# SMTP Configuration (Alternative to Microsoft Graph)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@domain.com
SMTP_PASS=your-app-password
SMTP_SENDER_EMAIL=your-email@domain.com
SMTP_SENDER_NAME=InvoSell System
